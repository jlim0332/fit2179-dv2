{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "AU games on Steam: an indie boom that never stopped",
    "subtitle": "AU-developed Steam releases per year, stacked by genre. Games tagged with multiple genres are counted once per genre.",
    "anchor": "start",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "subtitleColor": "#6B7280"
  },
  "width": 680,
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/jlim0332/fit2179-dv2/main/data/steam_au_yearly_genre.csv"
  },
  "mark": {
    "type": "area",
    "opacity": 0.95,
    "strokeWidth": 1
  },
  "encoding": {
    "x": {
      "field": "release_year",
      "type": "ordinal",
      "title": "Release year",
      "axis": {"labelAngle": 0}
    },
    "y": {
      "field": "n_games",
      "type": "quantitative",
      "title": "Games released (stacked by genre)",
      "stack": "zero"
    },
    "color": {
      "field": "genre",
      "type": "nominal",
      "sort": ["Indie", "Action", "Adventure", "Simulation", "Strategy", "Casual", "Sports", "RPG", "Free To Play", "Racing", "Early Access", "Massively Multiplayer"],
      "scale": {
        "domain": ["Indie", "Action", "Adventure", "Simulation", "Strategy", "Casual", "Sports", "RPG", "Free To Play", "Racing", "Early Access", "Massively Multiplayer"],
        "range": ["#F26B1F", "#1A1F36", "#7A2E00", "#00695C", "#6B4226", "#F9A064", "#DC2626", "#7C3AED", "#0EA5E9", "#FFD4A8", "#A8A29E", "#52525B"]
      },
      "legend": {
        "title": "Genre",
        "orient": "right",
        "titleFontSize": 11,
        "labelFontSize": 10
      }
    },
    "order": {
      "field": "genre",
      "type": "nominal"
    },
    "tooltip": [
      {"field": "release_year", "type": "ordinal", "title": "Year"},
      {"field": "genre", "type": "nominal", "title": "Genre"},
      {"field": "n_games", "type": "quantitative", "title": "Games"}
    ]
  }
}