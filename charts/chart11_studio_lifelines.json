{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "How long have AU studios been shipping on Steam?",
    "subtitle": "Release span of the top 15 AU studios, from first to most recent Steam release. Team Cherry highlighted.",
    "anchor": "start",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "subtitleColor": "#6B7280"
  },
  "width": 620,
  "height": 400,
  "background": "#FFFFFF",
  "data": {
    "url": "https://raw.githubusercontent.com/jlim0332/fit2179-dv2/main/data/steam_top15_studios.csv"
  },
  "encoding": {
    "y": {
      "field": "studio_name",
      "type": "nominal",
      "sort": {"field": "first_release_year", "order": "ascending"},
      "title": null,
      "axis": {"labelFontSize": 11, "labelPadding": 6}
    }
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "height": 12,
        "cornerRadius": 6,
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "field": "first_release_year",
          "type": "quantitative",
          "title": "Year",
          "scale": {"domain": [2009, 2026]},
          "axis": {"format": "d"}
        },
        "x2": {"field": "last_release_year"},
        "color": {
          "condition": {
            "test": "datum.studio_name == 'Team Cherry'",
            "value": "#F26B1F"
          },
          "value": "#C8C8C8"
        },
        "tooltip": [
          {"field": "studio_name", "type": "nominal", "title": "Studio"},
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "n_games", "type": "quantitative", "title": "# Games"},
          {"field": "first_release_year", "type": "quantitative", "title": "First release", "format": "d"},
          {"field": "last_release_year", "type": "quantitative", "title": "Latest release", "format": "d"},
          {"field": "total_reviews", "type": "quantitative", "title": "Total reviews", "format": ","}
        ]
      }
    }
  ]
}