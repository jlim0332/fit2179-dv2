{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Studios per state vs share of workers",
    "subtitle": "Two views of state-level industry weight. Same map, different metric.",
    "anchor": "start",
    "font": "Inter",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "subtitleColor": "#6B7280",
    "color": "#1A1F36"
  },
  "background": "transparent",
  "config": {
    "view": { "stroke": null },
    "font": "Inter"
  },
  "hconcat": [
    {
      "title": {
        "text": "Share of studios",
        "anchor": "start",
        "fontSize": 12,
        "color": "#1A1F36"
      },
      "width": 350,
      "height": 380,
      "projection": { "type": "equalEarth" },
      "data": {
        "url": "https://raw.githubusercontent.com/jlim0332/fit2179-dv2/main/topojson/australia_states.json",
        "format": { "type": "topojson", "feature": "australia_states" }
      },
      "transform": [
        {
          "lookup": "properties.STATE_NAME",
          "from": {
            "data": { "url": "https://raw.githubusercontent.com/jlim0332/fit2179-dv2/main/data/au_industry_state_breakdown.csv" },
            "key": "state",
            "fields": ["studio_pct", "fte_pct"]
          }
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#FFFFFF",
        "strokeWidth": 1
      },
      "encoding": {
        "color": {
          "field": "studio_pct",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [5, 15, 25],
            "range": ["#FFF1E5", "#FFD4A8", "#F9A064", "#F26B1F"]
          },
          "legend": {
            "title": "% of studios",
            "orient": "bottom",
            "titleFontSize": 10,
            "labelFontSize": 9
          }
        },
        "tooltip": [
          { "field": "properties.STATE_NAME", "type": "nominal", "title": "State" },
          { "field": "studio_pct", "type": "quantitative", "title": "Studios (%)" },
          { "field": "fte_pct", "type": "quantitative", "title": "Workers (%)" }
        ]
      }
    },
    {
      "title": {
        "text": "Share of workers",
        "anchor": "start",
        "fontSize": 12,
        "color": "#1A1F36"
      },
      "width": 350,
      "height": 380,
      "projection": { "type": "equalEarth" },
      "data": {
        "url": "https://raw.githubusercontent.com/jlim0332/fit2179-dv2/main/topojson/australia_states.json",
        "format": { "type": "topojson", "feature": "australia_states" }
      },
      "transform": [
        {
          "lookup": "properties.STATE_NAME",
          "from": {
            "data": { "url": "https://raw.githubusercontent.com/jlim0332/fit2179-dv2/main/data/au_industry_state_breakdown.csv" },
            "key": "state",
            "fields": ["studio_pct", "fte_pct"]
          }
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#FFFFFF",
        "strokeWidth": 1
      },
      "encoding": {
        "color": {
          "field": "fte_pct",
          "type": "quantitative",
          "scale": {
            "type": "threshold",
            "domain": [5, 15, 25],
            "range": ["#E0F2F1", "#80CBC4", "#26A69A", "#00695C"]
          },
          "legend": {
            "title": "% of workers",
            "orient": "bottom",
            "titleFontSize": 10,
            "labelFontSize": 9
          }
        },
        "tooltip": [
          { "field": "properties.STATE_NAME", "type": "nominal", "title": "State" },
          { "field": "studio_pct", "type": "quantitative", "title": "Studios (%)" },
          { "field": "fte_pct", "type": "quantitative", "title": "Workers (%)" }
        ]
      }
    }
  ]
}