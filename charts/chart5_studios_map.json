{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Australia's game studios on Steam",
    "subtitle": "Each circle is a studio with at least one Steam release. Position = home city. Size = number of games. Colour = average review score.",
    "anchor": "start",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "subtitleColor": "#6B7280"
  },
  "width": 700,
  "height": 500,
  "projection": {"type": "mercator"},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/jlim0332/fit2179-dv2/main/topojson/australia_states.json",
        "format": {"type": "topojson", "feature": "australia_states"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#F5F5F5",
        "stroke": "#FFFFFF",
        "strokeWidth": 1
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/jlim0332/fit2179-dv2/main/data/steam_au_studios_summary.csv"
      },
      "transform": [
        {
          "lookup": "city",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/jlim0332/fit2179-dv2/main/data/au_cities.csv"
            },
            "key": "city",
            "fields": ["latitude", "longitude"]
          }
        },
        {"filter": "datum.latitude != null"},
        {"calculate": "datum.longitude + (random() - 0.5) * 2.0", "as": "jittered_lng"},
        {"calculate": "datum.latitude + (random() - 0.5) * 1.5", "as": "jittered_lat"}
      ],
      "mark": {
        "type": "circle",
        "opacity": 0.8,
        "stroke": "#FFFFFF",
        "strokeWidth": 1
      },
      "encoding": {
        "longitude": {"field": "jittered_lng", "type": "quantitative"},
        "latitude": {"field": "jittered_lat", "type": "quantitative"},
        "size": {
          "field": "n_games",
          "type": "quantitative",
          "scale": {"range": [60, 800]},
          "title": "# games on Steam"
        },
        "color": {
          "field": "avg_review_pct_positive",
          "type": "quantitative",
          "scale": {
            "scheme": "oranges",
            "domain": [50, 100]
          },
          "title": "Avg review %"
        },
        "tooltip": [
          {"field": "studio_name", "type": "nominal", "title": "Studio"},
          {"field": "city", "type": "nominal", "title": "City"},
          {"field": "n_games", "type": "quantitative", "title": "# Games"},
          {"field": "avg_review_pct_positive", "type": "quantitative", "title": "Avg review %", "format": ".0f"},
          {"field": "total_reviews", "type": "quantitative", "title": "Total reviews", "format": ","}
        ]
      }
    }
  ],
  "config": {
    "legend": {
      "orient": "right",
      "titleFontSize": 10,
      "labelFontSize": 9
    }
  }
}